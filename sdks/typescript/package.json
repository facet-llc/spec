{
  "name": "@facet/sdk-js",
  "version": "0.0.1",
  "description": "Reference TypeScript SDK for the Facet Protocol. KYAPay verifier and Terminal client.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "jose": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "agentic-commerce",
    "kyapay",
    "x402",
    "mcp",
    "facet",
    "agent-identity"
  ],
  "homepage": "https://facet.llc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facet-llc/protocol.git",
    "directory": "sdks/typescript"
  },
  "bugs": "https://github.com/facet-llc/protocol/issues",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
